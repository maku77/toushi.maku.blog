<?xml version="1.0" encoding="utf-8" standalone="yes"?><rss version="2.0" xmlns:atom="http://www.w3.org/2005/Atom"><channel><title>TradeStation/ショウミー on まくまく投資ノート</title><link>https://toushi.maku.blog/p/9rprgvq/</link><description>Recent content in TradeStation/ショウミー on まくまく投資ノート</description><generator>Hugo</generator><language>ja-jp</language><atom:link href="https://toushi.maku.blog/p/9rprgvq/index.xml" rel="self" type="application/rss+xml"/><item><title>TradeStation/ショウミー/WA-New Low for Month（1ヶ月基準の安値更新）</title><link>https://toushi.maku.blog/p/hv33tqx/</link><pubDate>Mon, 01 Jan 0001 00:00:00 +0000</pubDate><guid>https://toushi.maku.blog/p/hv33tqx/</guid><description>&lt;figure class="xCodeBlock">
&lt;figcaption class="xCodeBlock_title">WA-New Low for Month&lt;/figcaption>
&lt;div class="xCodeBlock_code">&lt;div class="highlight">&lt;pre tabindex="0" class="chroma">&lt;code class="language-plain" data-lang="plain">&lt;span class="line">&lt;span class="cl">{ Search Tag: WA-New Low for Month }
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">variables:
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl"> LowestLo( 0 ) ;
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">{ tick, second, minute, daily or weekly bars }
