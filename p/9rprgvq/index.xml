&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl"> LowestLo = Low
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl"> else if Low &amp;lt; LowestLo then
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl"> begin
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl"> Plot1( Low, !( &amp;#34;NewLo-M&amp;#34; ) ) ;
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl"> Alert ;
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl"> LowestLo = Low ;
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl"> end ;
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl"> end ;&lt;/span>&lt;/span>&lt;/code>&lt;/pre>&lt;/div>&lt;/div>
&lt;/figure>

